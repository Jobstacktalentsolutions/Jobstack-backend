<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="supported-color-schemes" content="light dark" />
    <title>Application Update</title>
    <style>
      :root {
        color-scheme: light dark;
        supported-color-schemes: light dark;
      }
      @media (prefers-color-scheme: dark) {
        .email-container { background-color: #1a1a1a !important; }
        .email-content { background-color: #2d2d2d !important; color: #e0e0e0 !important; }
        .text-primary { color: #e0e0e0 !important; }
        .footer { background-color: #2d2d2d !important; color: #b0b0b0 !important; }
      }
    </style>
  </head>
  <body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f3f4f6;">
    <%
      const normalizedStatus = status.toLowerCase();
      const isPositiveStatus =
        normalizedStatus === 'accepted' ||
        normalizedStatus === 'approved' ||
        normalizedStatus === 'hired';
      const isNegativeStatus =
        normalizedStatus === 'rejected' || normalizedStatus === 'declined';
      const statusLabel = status.charAt(0).toUpperCase() + status.slice(1);
      let computedStatusMessage = '';
      let computedNextSteps = '';
      if (isPositiveStatus) {
        computedStatusMessage =
          'Good news. Your application is moving forward and the team will contact you with the next step.';
        computedNextSteps =
          'Keep an eye on your inbox and the app for the next update.';
      } else if (isNegativeStatus) {
        computedStatusMessage =
          'We reviewed your application and will not move forward at this time.';
        computedNextSteps =
          'You can continue exploring other jobs and apply when you find a better fit.';
      } else if (normalizedStatus === 'vetted') {
        computedStatusMessage =
          'Your application passed the initial review and is now under closer consideration.';
        computedNextSteps =
          'No action is required yet. We will update you if the hiring team wants to proceed.';
      } else if (normalizedStatus === 'screening') {
        computedStatusMessage =
          'Your application is in screening. The team is checking your profile and scheduling the next step.';
        computedNextSteps =
          'Prepare any requested documents and monitor your inbox for the interview details.';
      } else {
        computedStatusMessage =
          'Your application status has been updated in JobStack.';
        computedNextSteps =
          'Check the app for the latest information about this role.';
      }
    %>
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" class="email-container" style="background-color: #f3f4f6;">
      <tr>
        <td style="padding: 40px 20px;">
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="max-width: 600px; margin: 0 auto;">
            <tr>
              <td class="email-content" style="background-color: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                
                <!-- Logo Header -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                  <tr>
                    <td style="padding: 32px 32px 24px 32px; text-align: center;">
                      <img src="https://jobstack.org/email-assets/logo.svg" alt="Jobstack" width="120" height="58" style="display: block; margin: 0 auto;" />
                    </td>
                  </tr>
                </table>

                <!-- Content -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                  <tr>
                    <td style="padding: 0 32px 32px 32px;">
                      
                      <h1 class="header-text" style="margin: 0 0 16px 0; font-size: 24px; font-weight: 700; color: #111827; line-height: 1.2;">Application Update</h1>
                      
                      <p class="text-primary" style="margin: 0 0 16px 0; font-size: 16px; line-height: 1.5; color: #374151;">
                        Hi <%= recipientName %>,
                      </p>

                      <p class="text-primary" style="margin: 0 0 24px 0; font-size: 16px; line-height: 1.5; color: #374151;">
                        There is an update regarding your application for "<strong><%= jobTitle %></strong>" at <strong><%= companyName %></strong>.
                      </p>

                      <div style="padding: 20px; border-radius: 12px; margin-bottom: 24px; background-color: <%= status === 'accepted' || status === 'approved' || status === 'hired' ? '#f0fdf4' : status === 'rejected' || status === 'declined' ? '#fef2f2' : '#f8fafc' %>; border: 1px solid <%= status === 'accepted' || status === 'approved' || status === 'hired' ? '#bbf7d0' : status === 'rejected' || status === 'declined' ? '#fecaca' : '#e2e8f0' %>;">
                        <p style="margin: 0; font-size: 16px; font-weight: 600; color: <%= status === 'accepted' || status === 'approved' || status === 'hired' ? '#166534' : status === 'rejected' || status === 'declined' ? '#991b1b' : '#1e293b' %>">
                          Status: <%= statusLabel %>
                        </p>
                        <p style="margin: 8px 0 0 0; font-size: 14px; color: #475569; line-height: 1.5;"><%= computedStatusMessage %></p>
                      </div>

                      <div style="margin-bottom: 24px;">
                        <h3 style="margin: 0 0 8px 0; font-size: 16px; font-weight: 600; color: #111827;">Next Steps</h3>
                        <p style="margin: 0; font-size: 14px; color: #475569; line-height: 1.5;"><%= computedNextSteps %></p>
                      </div>

                      <!-- CTA Button -->
                      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin: 0 0 24px 0;">
                        <tr>
                          <td style="text-align: center;">
                            <a href="<%= actionUrl %>" style="display: inline-block; background-color: #123A52; color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; padding: 12px 32px; border-radius: 8px;"><%= actionText %></a>
                          </td>
                        </tr>
                      </table>

                    </td>
                  </tr>
                </table>

                <!-- Footer -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" class="footer" style="background-color: #f9fafb; border-top: 1px solid #e5e7eb;">
                  <tr>
                    <td style="padding: 24px 32px; text-align: center;">
                      <p class="text-secondary" style="margin: 0 0 8px 0; font-size: 13px; color: #6b7280;">
                        Questions? Contact us at <a href="mailto:<%= supportEmail %>" style="color: #123A52; text-decoration: none; font-weight: 500;"><%= supportEmail %></a>
                      </p>
                      <p class="text-secondary" style="margin: 0 0 8px 0; font-size: 13px; color: #6b7280;">
                        Or call <a href="tel:<%= supportPhoneNumber %>" style="color: #123A52; text-decoration: none; font-weight: 500;"><%= supportPhoneNumber %></a>
                      </p>
                      <p class="text-secondary" style="margin: 0; font-size: 12px; color: #9ca3af;">
                        © <%= currentYear %> <%= companyName %>. All rights reserved.
                      </p>
                    </td>
                  </tr>
                </table>

              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
